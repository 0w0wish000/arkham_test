{
  "name": "arkham-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Arkham LCG 電子化 — 前端客戶端(TypeScript + PixiJS)。只渲染伺服器狀態、送出意圖,無規則邏輯。",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "sync-db": "node scripts/sync-deckbuilder.mjs",
    "predev": "npm run sync-db",
    "prebuild": "npm run sync-db"
  },
  "dependencies": {
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
