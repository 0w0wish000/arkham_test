{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arkham 選牌器",
  "version": "0.1.0",
  "identifier": "com.arkham.deckbuilder",
  "build": {
    "frontendDist": "../prototype"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Arkham 選牌器(桌面)",
        "url": "deckbuilder.html",
        "width": 1500,
        "height": 950,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "comment": "打包(tauri build)前需先產生圖示:npx @tauri-apps/cli icon <一張 png>"
  }
}
